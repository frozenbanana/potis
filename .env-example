# Potis Environment Configuration
# Copy this file to .env and update the values

# Swarm Bee Configuration
# For local development with bee on host machine, use host.docker.internal
# For DappNode production, use http://bee.dappnode:1633
BEE_URL=http://host.docker.internal:1633

# Swarm Postage Batch ID (64-character hex string)
# Leave empty for in-memory mode (data lost on restart)
# Set to a valid batch ID for Swarm mode (persistent storage)
BATCH_ID=

# Example Swarm mode (uncomment to use):
# BEE_URL=http://bee.dappnode:1633
# BATCH_ID=96bec83a78b1c35b670ea38731a78bb7a4abd2399530bde4a986b5bd19b55b7b
